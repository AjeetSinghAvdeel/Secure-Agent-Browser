  "curl_examples": {
    "scan_with_ground_truth": "curl -X POST http://localhost:8000/scan -H 'Content-Type: application/json' -d '{\"url\": \"https://github.com\", \"ground_truth\": \"benign\"}'",
    "get_metrics": "curl http://localhost:8000/metrics",
    "get_false_positives": "curl 'http://localhost:8000/errors?error_type=FP&limit=20'",
    "get_false_negatives": "curl 'http://localhost:8000/errors?error_type=FN&domain=example&limit=10'",
    "get_error_analysis": "curl http://localhost:8000/metrics/error-analysis",
    "get_snapshot": "curl http://localhost:8000/metrics/snapshot",
    "export_metrics": "curl -H 'Authorization: Bearer ADMIN_TOKEN' http://localhost:8000/metrics/export",
    "reset_metrics": "curl -X POST -H 'Authorization: Bearer ADMIN_TOKEN' http://localhost:8000/metrics/reset"
  },

  "python_examples": {
    "update_metrics": "from metrics import update_metrics\nresult = update_metrics(\n    risk_score=75,\n    ground_truth='malicious',\n    url='https://malware.com',\n    confidence=0.95,\n    attack_type='Phishing'\n)",
    "get_misclassifications": "from metrics import get_tracker\ntracker = get_tracker()\nfps = tracker.get_misclassifications(error_type='FP', limit=10)\nfor fp in fps:\n    print(f'{fp.url}: {fp.reason}')",
    "get_suggestions": "analysis = tracker.get_error_analysis()\nfor suggestion in analysis['improvement_suggestions']:\n    print(suggestion)",
    "measure_usability": "from task_success_harness import TaskSuccessHarness\nharness = TaskSuccessHarness()\nharness.register_default_scenarios()\nfor scenario_id in harness.scenarios:\n    harness.run_task(scenario_id, secure_agent_enabled=False)\n    harness.run_task(scenario_id, secure_agent_enabled=True)\nmetrics = harness.compute_metrics()"
  },

  "react_examples": {
    "import_dashboard": "import MetricsDashboard from './components/MetricsDashboard';\n\n<MetricsDashboard userId='user123' />",
    "fetch_metrics": "const response = await fetch('/metrics');\nconst data = await response.json();\nconsole.log(`Precision: ${(data.precision * 100).toFixed(1)}%`);",
    "fetch_errors": "const params = new URLSearchParams({ error_type: 'FP', limit: '20' });\nconst response = await fetch(`/errors?${params}`);\nconst data = await response.json();"
  }
}
