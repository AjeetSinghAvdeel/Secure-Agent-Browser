{
  "manifest_version": 3,
  "name": "SecureAgent",
  "version": "1.0.0",
  "description": "AI-powered pre-navigation web threat detection",
  "permissions": [
    "tabs",
    "activeTab",
    "webNavigation",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/secureagent-128.png",
    "48": "icons/secureagent-128.png",
    "128": "icons/secureagent-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["warning.html", "warning.js", "icons/secureagent.svg", "icons/secureagent-128.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "SecureAgent",
    "default_icon": {
      "16": "icons/secureagent-128.png",
      "48": "icons/secureagent-128.png",
      "128": "icons/secureagent-128.png"
    }
  }
}
